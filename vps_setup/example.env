# =========================
# Projekt / Domain
# =========================
NODE_ENV=production
PORT=3000
CANONICAL_HOST=www.example.de
BASE_URL=https://www.example.de
SITE_BASE_URL=https://www.example.de
SITE_NAME=Example Projekt
SITE_DEFAULT_LOCALE=de-DE
SITE_DOMAIN=example.de
SITE_HOST_ROOT=example.de
SITE_HOST_WWW=www.example.de
HOOKS_HOST=hooks.example.de
DEPLOY_BRANCH=main

# =========================
# PostgreSQL (Container + App)
# =========================
POSTGRES_USER=example_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=example_db

DB_HOST=postgres
DB_PORT=5432
DB_USER=example_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=example_db
DB_SSL=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=10000
DB_APP_NAME=example-project
# Alternative: statt DB_HOST/DB_* kann direkt DATABASE_URL gesetzt werden
# DATABASE_URL=postgresql://example_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/example_db

# =========================
# Sessions / Security
# =========================
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
BOOKING_TOKEN_SECRET=CHANGE_ME_BOOKING_SECRET
ADMIN_REGISTRATION_KEY=OPTIONAL_ADMIN_INVITE_KEY

# =========================
# OAuth (Google)
# =========================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://www.example.de/auth/google/callback

# =========================
# Mail / SMTP
# =========================
SMTP_HOST=smtp.example.de
SMTP_PORT=587
SMTP_USER=user@example.de
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM="Example Projekt <info@example.de>"
CONTACT_ADMIN_TO=info@example.de
NEWSLETTER_FROM="Newsletter <newsletter@example.de>"

# =========================
# Analytics / Tracking
# =========================
GA_MEASUREMENT_ID=G-XXXXXXXXXX
CLARITY_ID=xxxxxxxxxx

# =========================
# Bot-Schutz Kontaktformular
# =========================
RECAPTCHA_ENABLED=true
# reCAPTCHA v3 Schlüssel
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
# Erwartete Action aus dem Frontend (grecaptcha.execute(..., { action: ... }))
RECAPTCHA_EXPECTED_ACTION=contact_form
# Mindestscore für Akzeptanz (0.0 - 1.0)
RECAPTCHA_MIN_SCORE=0.5

# =========================
# Upload / Medienverarbeitung
# =========================
UPLOAD_ROOT=/app/public/uploads
MAX_IMAGE_WIDTH=2000
IMAGE_WEBP_QUALITY=80
VIDEO_TRANSCODE=true
VIDEO_MAX_WIDTH=1920
VIDEO_MAX_HEIGHT=1080
VIDEO_CRF=28
VIDEO_PRESET=medium
AUDIO_BITRATE=128k

# =========================
# Cloudinary (optional)
# =========================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER_IMAGES=example/images
CLOUDINARY_FOLDER_VIDEOS=example/videos

# =========================
# Webhook Deploy
# =========================
WEBHOOK_SECRET=CHANGE_ME_GITHUB_WEBHOOK_SECRET
WEBHOOK_PORT=4000
# wird i. d. R. via compose gesetzt, kann hier aber überschrieben werden:
# DEPLOY_SCRIPT=/apps/example-project/deploy/deploy.sh
